{
  "name": "turtle-soup-mystery",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "front",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:front\"",
    "dev:backend": "npm run dev --workspace backend",
    "dev:front": "npm run dev --workspace front",
    "build": "npm run build --workspace front && node scripts/copy-frontend-dist.mjs && npm run build --workspace backend",
    "start": "npm run start --workspace backend",
    "init:data": "npm run init:data --workspace backend"
  },
  "devDependencies": {
    "concurrently": "9.2.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
