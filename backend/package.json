    "init:data": "node --disable-warning=ExperimentalWarning --import tsx/esm src/scripts/initData.ts"
  },
  "dependencies": {
    "axios": "1.13.6",
    "cors": "2.8.6",
    "express": "5.2.1",
    "nanoid": "5.1.7",
    "ws": "^8.20.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/ws": "^8.18.1",
    "tsx": "4.21.0",
    "typescript": "6.0.2"
  }
}
